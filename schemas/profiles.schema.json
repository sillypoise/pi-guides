{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sillypoise.dev/pi-guides/schemas/profiles.schema.json",
  "title": "Pi Guides Profile Registry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "profiles": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "guides": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "mode": {
            "type": "string",
            "enum": ["compact", "full"]
          }
        },
        "required": ["title", "guides"]
      }
    }
  },
  "required": ["version", "profiles"]
}
